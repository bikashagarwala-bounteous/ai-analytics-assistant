# ── App ─────────────────────────────────────────────────────────────
APP_NAME=AI Analytics MCP Server
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# ── MCP Server ──────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8001
MCP_PATH=/mcp

# ── Gemini ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

GEMINI_RPM_LIMIT=10
GEMINI_RPD_LIMIT=1500
GEMINI_TPM_LIMIT=250000

GEMINI_MAX_RETRIES=5
GEMINI_RETRY_MIN_WAIT=1.0
GEMINI_RETRY_MAX_WAIT=60.0
GEMINI_RETRY_JITTER_MAX=2.0

# ── PostgreSQL ──────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=analytics
POSTGRES_USER=analytics_user
POSTGRES_PASSWORD=your_postgres_password_here
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20

# ── Redis ───────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# Cache TTLs (seconds)
CACHE_TTL_LLM_RESPONSE=3600
CACHE_TTL_EMBEDDING=86400
CACHE_TTL_ANALYSIS=1800
CACHE_TTL_RAG_RETRIEVAL=900
CACHE_TTL_STREAM_PARTIAL=300

# ── ChromaDB ────────────────────────────────────────────────────────
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000
CHROMADB_COLLECTION_CONVERSATIONS=conversations
CHROMADB_COLLECTION_INTENTS=intents

# ── Embedding ───────────────────────────────────────────────────────
EMBEDDING_BATCH_SIZE=50
EMBEDDING_DIMENSION=3072

# ── LangSmith (Optional) ────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-analytics-assistant
LANGSMITH_ENDPOINT=https://api.smith.langchain.com